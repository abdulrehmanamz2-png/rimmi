<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional SaaS Builder</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; text-align: center; padding: 20px; background-color: #f4f7f6; }
        .box { background: white; padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); max-width: 400px; margin: auto; }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box; }
        button { background-color: #6c63ff; color: white; border: none; padding: 15px; border-radius: 10px; width: 100%; font-weight: bold; cursor: pointer; }
        
        #portfolio-result { display: none; margin-top: 30px; border-top: 5px solid #6c63ff; }
        .wa-btn { background-color: #25D366; text-decoration: none; color: white; padding: 10px 20px; border-radius: 50px; display: inline-block; margin-top: 15px; font-weight: bold; }
    </style>
</head>
<body>

    <div class="box" id="input-form">
        <h2 style="color: #6c63ff;">Portfolio Creator 🛠️</h2>
        <p>Apni details bhar kar website banayein:</p>
        
        <input type="text" id="name" placeholder="Pura Naam">
        <input type="text" id="skill" placeholder="Aap kya kaam karte hain?">
        <input type="number" id="phone" placeholder="WhatsApp Number (92300...)">
        
        <button onclick="saveData()">Create My Portfolio</button>
    </div>

    <div id="portfolio-result" class="box">
        <h1 id="out-name"></h1>
        <h3 id="out-skill" style="color: #666;"></h3>
        <p>Mujhse kaam ke liye yahan rabta karein:</p>
        <a id="wa-link" href="#" class="wa-btn">Send WhatsApp Message</a>
        <br><br>
        <button style="background: #ff4757;" onclick="resetAll()">Reset / Delete</button>
    </div>

    <script>
        window.onload = function() {
            var data = JSON.parse(localStorage.getItem("myPortfolioData"));
            if(data) { display(data); }
        }

        function saveData() {
            var userObj = {
                name: document.getElementById("name").value,
                skill: document.getElementById("skill").value,
                phone: document.getElementById("phone").value
            };

            if(userObj.name && userObj.skill && userObj.phone) {
                localStorage.setItem("myPortfolioData", JSON.stringify(userObj));
                display(userObj);
            } else {
                alert("Please saari fields bharein!");
            }
        }

        function display(data) {
            document.getElementById("input-form").style.display = "none";
            document.getElementById("portfolio-result").style.display = "block";
            
            document.getElementById("out-name").innerText = data.name;
            document.getElementById("out-skill").innerText = data.skill;
            document.getElementById("wa-link").href = "https://wa.me/" + data.phone;
        }

        function resetAll() {
            localStorage.clear();
            location.reload();
        }
    </script>

</body>
</html>

       